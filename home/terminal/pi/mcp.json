{
  "mcpServers": {
   "duckduckgo": {
      "command": "npx",
      "args": ["-y", "ddg-mcp-search"]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--headless"
      ],
      "directTools": [
        "browser_handle_dialog",
        "browser_navigate",
        "browser_click",
        "browser_wait_for"
      ]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "directTools": true
    }
  }
}
